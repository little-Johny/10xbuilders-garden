# ============================================================================
# Variables de entorno — Agente personal (MVP)
#
# Copia este archivo a apps/web/.env.local y completa los valores:
#   cp .env.example apps/web/.env.local
#
# Next.js carga .env* desde apps/web, NO desde la raíz del monorepo.
# Guía de setup completa en el README.md (pasos 2, 5, 8-13).
# ============================================================================

# --- Supabase (requerido) — Project Settings → API -------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Connection string de Postgres (checkpointer de LangGraph).
# Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=

# --- OpenRouter (requerido) -------------------------------------------------
OPENROUTER_API_KEY=
# Modelo principal del agente (ej. openai/gpt-oss-120b:free)
OPENROUTER_MODEL=
# Modelo dedicado a compactar historial (memoria a corto plazo)
OPENROUTER_COMPACTION_MODEL=
# (Opcional) Modelo de extracción de memoria a largo plazo; cae a COMPACTION
OPENROUTER_MEMORY_MODEL=
# (Opcional) Modelo de embeddings. Default: openai/text-embedding-3-small
OPENROUTER_EMBEDDING_MODEL=

# --- Memoria a largo plazo (opcional, defaults sensatos) --------------------
# Fallback del umbral de inactividad para el flush automático (default 30)
MEMORY_FLUSH_IDLE_MINUTES=
# Mínimo de turnos de usuario para flushear una sesión (default 2)
MEMORY_FLUSH_MIN_TURNS=
# Top-K de recuerdos a inyectar por turno (default 6)
MEMORY_RETRIEVAL_K=
# Cosine mínima para considerar duplicado al guardar (default 0.90)
MEMORY_DEDUP_THRESHOLD=

# --- Seguridad (requerido) ---------------------------------------------------
# Cifrado AES-256-GCM de tokens OAuth. Genera con: openssl rand -base64 32
OAUTH_ENCRYPTION_KEY=

# --- App ---------------------------------------------------------------------
# (Opcional) URL base de la app. Default: http://localhost:3000
# Necesaria para los callbacks OAuth de GitHub y Google
NEXT_PUBLIC_APP_URL=

# --- GitHub OAuth (opcional) -------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth (opcional — Calendar + Sheets) -----------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Telegram (opcional) -----------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# (Opcional) URL pública HTTPS para registrar el webhook (ej. la de ngrok)
TELEGRAM_WEBHOOK_BASE_URL=

# --- Gates de tools (opcional) -----------------------------------------------
# true/1 para exponer la tool bash (riesgo alto, HITL)
ALLOW_BASH_TOOL=
# (Opcional) Sandbox de la tool bash: confina cwd a este root
BASH_WORKSPACE_ROOT=
# true/1 para exponer read_file / write_file / edit_file
ALLOW_FILE_TOOLS=
# (Opcional) Sandbox de file tools: confina toda ruta a este root
FILE_TOOLS_WORKSPACE_ROOT=
# (Opcional) Cap de bytes para file tools (default 1000000)
FILE_TOOL_MAX_BYTES=

# --- Tareas programadas (opcional) --------------------------------------------
ALLOW_SCHEDULED_TASKS_TOOL=
# Secreto compartido con pg_cron. Genera con: openssl rand -hex 32
CRON_SECRET=

# --- Observabilidad — Langfuse self-hosted (opcional) --------------------------
# Sin estas 3 variables el tracing se desactiva silenciosamente.
# Setup en README.md paso 13 (Docker, puerto remapeado a 3001)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
