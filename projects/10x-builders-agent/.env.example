# ============================================================================
# Variables de entorno — Agente personal (MVP)
#
# Copia este archivo a apps/web/.env.local y completa los valores:
#   cp .env.example apps/web/.env.local
#
# Next.js carga .env* desde apps/web, NO desde la raíz del monorepo.
# Guía de setup completa en el README.md (pasos 2, 5, 8-13).
#
# Índice por feature:
#   1. Supabase (BD + auth)          6. Google OAuth (Calendar + Sheets)
#   2. OpenRouter (LLM)              7. Telegram bot
#   3. Memoria a largo plazo        8. Gates de tools (bash / file)
#   4. Seguridad (cifrado OAuth)    9. Tareas programadas
#   5. GitHub OAuth                10. Observabilidad (Langfuse)
#
# Convención: los NEXT_PUBLIC_* se exponen al navegador (nunca metas secretos
# ahí). El resto solo vive en el server. Todo secreto real va en .env.local,
# que está gitignoreado — este archivo NUNCA lleva valores.
# ============================================================================


# --- 1. Supabase (requerido) — Project Settings → API -----------------------
# URL pública del proyecto Supabase.
NEXT_PUBLIC_SUPABASE_URL=
# Clave anónima para el cliente del navegador (respeta RLS). Pública por diseño.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave service-role: SALTA RLS. Solo server-side (p. ej. cron de flush). Secreta.
SUPABASE_SERVICE_ROLE_KEY=
# Connection string de Postgres (checkpointer de LangGraph). Incluye password.
# Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=


# --- 2. OpenRouter (requerido) — el LLM del agente --------------------------
# API key de OpenRouter. Secreta.
OPENROUTER_API_KEY=
# Modelo principal del agente. Debe ser un slug ':free' (restricción de costo).
# OJO: los ':free' se retiran sin aviso; ante 404 MODEL_NOT_FOUND consulta
# https://openrouter.ai/api/v1/models y elige otro ':free' con soporte de tools.
# Ej. actual: openai/gpt-oss-20b:free
OPENROUTER_MODEL=
# Modelo dedicado a compactar historial (memoria a corto plazo).
OPENROUTER_COMPACTION_MODEL=
# (Opcional) Modelo de extracción de memoria a largo plazo; cae a COMPACTION.
OPENROUTER_MEMORY_MODEL=
# (Opcional) Modelo de embeddings. Default: openai/text-embedding-3-small
OPENROUTER_EMBEDDING_MODEL=


# --- 3. Memoria a largo plazo (opcional, defaults sensatos) -----------------
# Fallback del umbral de inactividad para el flush automático (default 30).
MEMORY_FLUSH_IDLE_MINUTES=
# Mínimo de turnos de usuario para flushear una sesión (default 2).
MEMORY_FLUSH_MIN_TURNS=
# Top-K de recuerdos a inyectar por turno (default 6).
MEMORY_RETRIEVAL_K=
# Cosine mínima para considerar duplicado al guardar (default 0.90).
MEMORY_DEDUP_THRESHOLD=


# --- 4. Seguridad (requerido) -----------------------------------------------
# Cifrado AES-256-GCM de los tokens OAuth de terceros guardados en la BD.
# Cualquier string no vacío sirve (se hashea a 32 bytes con SHA-256). Rotarlo
# invalida todo lo cifrado (habría que reconectar). Genera: openssl rand -base64 48
OAUTH_ENCRYPTION_KEY=

# (Opcional) URL base same-origin de la app. Default: http://localhost:3000
# Necesaria para los callbacks OAuth de GitHub y Google. Tras ngrok, el host ngrok.
NEXT_PUBLIC_APP_URL=


# --- 5. GitHub OAuth (opcional) ---------------------------------------------
# Crea una OAuth App en https://github.com/settings/developers.
# Authorization callback URL: <NEXT_PUBLIC_APP_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# --- 6. Google OAuth (opcional — Calendar + Sheets) -------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URI de callback tras autorizar en Google. Default local:
#   http://localhost:3000/api/auth/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=


# --- 7. Telegram (opcional) -------------------------------------------------
# Token del bot (BotFather). Secreto.
TELEGRAM_BOT_TOKEN=
# Secreto que valida que los webhooks entrantes vienen de Telegram.
TELEGRAM_WEBHOOK_SECRET=
# (Opcional) URL pública HTTPS para registrar el webhook (ej. la de ngrok).
TELEGRAM_WEBHOOK_BASE_URL=


# --- 8. Gates de tools (opcional) -------------------------------------------
# true/1 para exponer la tool bash (riesgo alto, pasa por HITL).
ALLOW_BASH_TOOL=
# (Opcional) Sandbox de la tool bash: confina el cwd a este root.
BASH_WORKSPACE_ROOT=
# true/1 para exponer read_file / write_file / edit_file.
ALLOW_FILE_TOOLS=
# (Opcional) Sandbox de file tools: confina toda ruta a este root.
FILE_TOOLS_WORKSPACE_ROOT=
# (Opcional) Cap de bytes para file tools (default 1000000).
FILE_TOOL_MAX_BYTES=


# --- 9. Tareas programadas (opcional) ---------------------------------------
# true/1 para exponer la tool de tareas programadas del agente.
ALLOW_SCHEDULED_TASKS_TOOL=
# Secreto compartido con pg_cron que autoriza los endpoints de tick.
# Genera con: openssl rand -hex 32
CRON_SECRET=


# --- 10. Observabilidad — Langfuse self-hosted (opcional) -------------------
# Sin estas 3 variables el tracing se desactiva silenciosamente (no-op seguro).
# Setup en README.md paso 13 (Docker, UI remapeada al puerto 3001).
# Clave pública del proyecto (pk-lf-...).
LANGFUSE_PUBLIC_KEY=
# Clave privada del proyecto (sk-lf-...). Secreta.
LANGFUSE_SECRET_KEY=
# URL del servidor Langfuse. El código acepta LANGFUSE_BASE_URL o LANGFUSE_BASEURL.
LANGFUSE_BASE_URL=http://localhost:3001
