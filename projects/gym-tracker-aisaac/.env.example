# Google Sheets API
GOOGLE_APPLICATION_CREDENTIALS=./credentials/aisaac-sa.json
SPREADSHEET_ID=
SHEET_NAME=progress_tracker

# OpenRouter (LLM routing)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=

# Optional: only set when running the gated integration test
TEST_SPREADSHEET_ID=

# Optional: set to 1 to print tool invocations to stderr (debug mode)
AISAAC_DEBUG=
